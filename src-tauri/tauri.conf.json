{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Specture",
  "version": "0.2.0",
  "identifier": "com.azeveco.specture",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Specture Editor",
        "width": 1000,
        "height": 700,
        "visible": false,
        "center": true
      },
      {
        "label": "control-panel",
        "title": "Specture Options",
        "width": 400,
        "height": 160,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "resizable": false
      },
      {
        "label": "region-selector",
        "title": "Select Region",
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      },
      {
        "label": "settings",
        "title": "Specture Settings",
        "width": 900,
        "height": 550,
        "visible": false,
        "center": true,
        "resizable": false
      },
      {
        "label": "stop-recording",
        "title": "Stop",
        "width": 80,
        "height": 80,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "skipTaskbar": true,
        "acceptFirstMouse": true,
        "url": "/?mode=stop-recording"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
